---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import ProjectCard from "../components/ProjectCard.astro";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const allTags = [...new Set(projects.flatMap((p) => p.data.tags ?? []))].sort();
---

<Base title="Projets — PortfolioHub">

  <!-- Page header -->
  <div class="mb-2 text-xs text-[#007a1f] font-mono">
    <span class="text-[#00aa2a]">$</span> ls -la ./projects/ <span class="text-[#005c17]">| sort -r</span>
  </div>
  <h1 class="text-2xl font-bold text-[#00ff41] mb-1" data-i18n="projects.heading">Hub de Projets</h1>
  <p class="text-xs text-[#007a1f] mb-6">
    <span class="text-[#00aa2a]">{projects.length} <span data-i18n="projects.entries">entrées trouvées</span></span>
    <span class="text-[#005c17]" data-i18n="projects.filter.hint"> — utilisez les filtres pour affiner</span>
  </p>

  <!-- Filter section -->
  <div class="border border-[#00ff41]/15 bg-[#0a0a0a] p-4 mb-6">
    <p class="text-[10px] uppercase tracking-[0.2em] text-[#007a1f] mb-3 font-bold">
      <span class="text-[#00aa2a]">$</span> grep --tags
    </p>

    <!-- Tags -->
    <div id="filters" class="flex flex-wrap gap-2">
      <button
        data-tag="__all"
        class="px-3 py-1 border border-[#00ff41]/25 text-xs text-[#00aa2a] transition-colors font-mono
               hover:border-[#00ff41]/55 hover:text-[#00ff41] hover:bg-[#00ff41]/5
               aria-[pressed=true]:border-[#00ff41]/55 aria-[pressed=true]:text-[#00ff41] aria-[pressed=true]:bg-[#00ff41]/10"
        aria-pressed="true"
      >
        [ ALL ]
      </button>
      {
        allTags.map((t) => (
          <button
            data-tag={t}
            class="px-3 py-1 border border-[#00ff41]/20 text-xs text-[#00aa2a] transition-colors font-mono
                   hover:border-[#00ff41]/50 hover:text-[#00ff41] hover:bg-[#00ff41]/5
                   aria-[pressed=true]:border-[#00ff41]/55 aria-[pressed=true]:text-[#00ff41] aria-[pressed=true]:bg-[#00ff41]/10"
            aria-pressed="false"
          >
            {t}
          </button>
        ))
      }
    </div>

    <!-- AND/OR toggle -->
    <div class="mt-3 flex items-center gap-3">
      <span class="text-xs text-[#007a1f] font-mono" data-i18n="projects.filter.label">mode_filtre :</span>
      <button
        id="modeToggle"
        class="relative w-28 h-8 border border-[#00ff41]/25 bg-[#080808] overflow-hidden
               focus:outline-none focus:border-[#00ff41]/50 transition inline-flex items-center font-mono"
      >
        <span
          id="slider"
          class="absolute inset-1 w-[calc(50%-0.2rem)] h-[calc(100%-0.5rem)]
                 bg-[#00ff41]/15 border border-[#00ff41]/35 transition-transform duration-200 z-0"
        ></span>
        <span id="lblAnd" class="relative z-10 flex-1 text-center text-[10px] font-bold select-none text-[#00ff41]" data-i18n="projects.filter.and">ET</span>
        <span id="lblOr"  class="relative z-10 flex-1 text-center text-[10px] font-bold select-none text-[#007a1f]" data-i18n="projects.filter.or">OU</span>
      </button>
    </div>
  </div>

  <!-- Project grid -->
  <div id="grid" class="grid sm:grid-cols-2 xl:grid-cols-3 gap-5 mt-2">
    {projects.map((p) => <ProjectCard entry={p} />)}
  </div>

  <!-- Filter script -->
  <script type="module">
    const grid = document.getElementById("grid");
    const btns = document.querySelectorAll("#filters [data-tag]");
    let active = new Set();
    let mode = "AND";

    const toggle = document.getElementById("modeToggle");
    const slider = document.getElementById("slider");
    const lblAnd = document.getElementById("lblAnd");
    const lblOr  = document.getElementById("lblOr");

    const setPressed = (el, pressed) =>
      el.setAttribute("aria-pressed", pressed ? "true" : "false");

    const updateSlider = () => {
      const isAnd = mode === "AND";
      slider.style.transform = isAnd ? "translateX(0)" : "translateX(100%)";
      lblAnd.classList.toggle("text-[#00ff41]", isAnd);
      lblAnd.classList.toggle("text-[#007a1f]", !isAnd);
      lblOr.classList.toggle("text-[#00ff41]", !isAnd);
      lblOr.classList.toggle("text-[#007a1f]", isAnd);
    };

    function apply() {
      for (const el of grid.children) {
        const tags = (el.getAttribute("data-tags") || "").split(",").filter(Boolean);
        let show = true;
        if (active.size > 0) {
          show = mode === "AND"
            ? [...active].every((t) => tags.includes(t))
            : [...active].some((t) => tags.includes(t));
        }
        el.classList.toggle("hidden", !show);
      }
    }

    for (const btn of btns) {
      btn.addEventListener("click", () => {
        const tag = btn.dataset.tag;
        if (tag === "__all") {
          active.clear();
          btns.forEach((b) => setPressed(b, b.dataset.tag === "__all"));
        } else {
          btns.forEach((b) => { if (b.dataset.tag === "__all") setPressed(b, false); });
          if (active.has(tag)) { active.delete(tag); setPressed(btn, false); }
          else { active.add(tag); setPressed(btn, true); }
          if (active.size === 0) {
            const all = document.querySelector('#filters [data-tag="__all"]');
            setPressed(all, true);
          }
        }
        apply();
      });
    }

    toggle.addEventListener("click", () => {
      mode = mode === "AND" ? "OR" : "AND";
      updateSlider();
      apply();
    });

    updateSlider();
  </script>
</Base>
