---
import Base from "../layouts/Base.astro";
import skills from "../data/skills.json";

function badge(level) {
  const colors = {
    "Expert": "bg-purple-700 text-white",
    "Avancé": "bg-purple-600 text-white",
    "Intermédiaire": "bg-purple-500/40 text-purple-300 border border-purple-600/40",
    "En apprentissage": "bg-zinc-800 text-zinc-400 border border-zinc-700",
  };
  return colors[level] ?? "bg-zinc-800 text-zinc-400";
}
---

<Base title="Compétences — Gautier Playbook">

  <h1 class="text-3xl font-bold mb-8">Mes Compétences</h1>

  <!-- 1. Domaines d’expertise -->
  <section class="mb-12">
    <h2 class="text-2xl font-semibold mb-4">Domaines d’expertise</h2>

    <div class="grid md:grid-cols-2 gap-4">
      {skills.expertise.map((e) => (
        <div class="p-4 rounded-2xl border border-zinc-800 bg-zinc-900/40">
          <h3 class="font-semibold text-lg mb-1">{e.icon} {e.title}</h3>
          <p class="text-zinc-400 text-sm">{e.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- 2. Sections -->
  <section class="grid lg:grid-cols-3 gap-10">

    <!-- Développement -->
    <div>
      <h2 class="text-xl font-semibold mb-4">🔧 Développement</h2>
      <ul class="space-y-3">
        {skills.sections.developpement.map(s => (
          <li class="flex items-center justify-between">
            <span>{s.label}</span>
            <span class={`px-2 py-0.5 rounded-full text-xs ${badge(s.level)}`}>{s.level}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- QA -->
    <div>
      <h2 class="text-xl font-semibold mb-4">🧪 QA & Automatisation</h2>
      <ul class="space-y-3">
        {skills.sections.qa.map(s => (
          <li class="flex items-center justify-between">
            <span>{s.label}</span>
            <span class={`px-2 py-0.5 rounded-full text-xs ${badge(s.level)}`}>{s.level}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Pro -->
    <div>
      <h2 class="text-xl font-semibold mb-4">🧑‍💼 Professionnelles</h2>
      <ul class="space-y-3">
        {skills.sections.professionnelles.map(s => (
          <li class="flex items-center justify-between">
            <span>{s.label}</span>
            <span class={`px-2 py-0.5 rounded-full text-xs ${badge(s.level)}`}>{s.level}</span>
          </li>
        ))}
      </ul>
    </div>

  </section>

  <!-- 3. Tools -->
  <section class="mt-12">
    <h2 class="text-xl font-semibold mb-4">🛠 Frameworks & Outils</h2>

    <div class="space-y-6">
      {Object.entries(skills.tools).map(([cat, items]) => (
        <div>
          <p class="text-sm text-zinc-400 mb-2">{cat}</p>
          <div class="flex flex-wrap gap-2">
            {items.map(i => (
              <span class="px-3 py-1.5 rounded-full border border-zinc-700 text-sm bg-zinc-900/40">{i}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 4. Metrics -->
  <section class="mt-12 grid md:grid-cols-3 gap-6">
    <div class="rounded-2xl border border-zinc-800 p-5 bg-zinc-900/40">
      <p class="text-sm text-zinc-400">Perf Web moyenne</p>
      <p class="text-3xl font-semibold mt-1">{skills.metrics.performance}</p>
    </div>

    <div class="rounded-2xl border border-zinc-800 p-5 bg-zinc-900/40">
      <p class="text-sm text-zinc-400">Couverture E2E</p>
      <p class="text-3xl font-semibold mt-1">{skills.metrics.coverage}</p>
    </div>

    <div class="rounded-2xl border border-zinc-800 p-5 bg-zinc-900/40">
      <p class="text-sm text-zinc-400">Déploiements/mois</p>
      <p class="text-3xl font-semibold mt-1">{skills.metrics.deployments}</p>
    </div>
  </section>

</Base>
