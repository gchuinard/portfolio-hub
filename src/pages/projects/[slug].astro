---
import Base from "../../layouts/Base.astro";
import { getCollection, getEntry } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("projects");
  return entries.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = await getEntry("projects", slug);
if (!project) return Astro.redirect("/projects");

const { Content } = await project.render();
const { title, description, tags = [], stack = [], image, date, demo, live, repo, repoPrivate } = project.data;
const imageIsSvg = image?.toLowerCase().endsWith(".svg") ?? false;

// Raison "ACCESS DENIED" spécifique au projet (modal des repos privés).
const lockInfo: Record<string, { classification: string; reason: string }> = {
  "gotyeah-yoga": {
    classification: "production · SaaS client",
    reason: "données client réelles + paiements Stripe",
  },
  "observatoire-emploi-tech": {
    classification: "production · pipeline de données",
    reason: "clés API & logique de collecte propriétaires",
  },
  "watch": {
    classification: "homelab · monitoring privé",
    reason: "expose des internals système du Pi (sécu infra)",
  },
};
const lock = lockInfo[slug ?? ""] ?? {
  classification: "private repository",
  reason: "code source confidentiel",
};
---

<Base title={`${title}, Projet`} description={description}>

  <!-- Breadcrumb -->
  <div class="mb-4 text-xs text-[#007a1f] font-mono">
    <span class="text-[#00aa2a]">$</span> cd ./projects/{slug}/
  </div>
  <a href="/projects" class="text-xs text-[#00aa2a] hover:text-[#00ff41] transition-colors font-mono">
    &larr; cd ../ (retour aux projets)
  </a>

  <!-- Header -->
  <header class="mt-4 terminal-window p-6">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div>
        <!-- Command prompt -->
        <p class="text-[10px] text-[#007a1f] font-mono mb-1">
          <span class="text-[#00aa2a]">$</span> cat {slug}.md
        </p>
        <h1 class="text-2xl font-bold text-[#00ff41]">{title}</h1>
        <p class="text-sm text-[#00aa2a] mt-1">{description}</p>
        <p class="text-[10px] text-[#007a1f] font-mono mt-1">
          <span class="text-[#005c17]">date:</span> {date.toLocaleDateString("fr-FR")}
        </p>

        <!-- Tags -->
        <div class="mt-3 flex flex-wrap gap-1.5">
          {tags.map(t => (
            <span class="text-[10px] px-2 py-0.5 border border-[#00ff41]/18 bg-[#080808] text-[#007a1f] font-mono">
              #{t}
            </span>
          ))}
        </div>

        <!-- Stack -->
        {stack.length > 0 && (
          <p class="mt-2 text-xs text-[#007a1f] font-mono">
            <span class="text-[#005c17]">stack:</span>{" "}
            <span class="text-[#00aa2a]">{stack.join(" · ")}</span>
          </p>
        )}
      </div>

      <!-- Action buttons -->
      <div class="flex gap-3 flex-shrink-0">
        {live && (
          <a
            href={live}
            target="_blank"
            rel="noopener"
            class="cta-luxe px-4 py-2 text-xs font-bold inline-flex items-center gap-1.5"
          >
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>
            &gt; live
          </a>
        )}
        {demo && (
          <a
            href={demo}
            target="_blank"
            class="cta-luxe px-4 py-2 text-xs font-bold"
          >
            &gt; demo
          </a>
        )}
        {repo && !repoPrivate && (
          <a
            href={repo}
            target="_blank"
            class="border border-[#00ff41]/25 bg-transparent px-4 py-2 text-xs text-[#00aa2a] font-mono hover:border-[#00ff41]/55 hover:text-[#00ff41] transition-colors"
          >
            &gt; code
          </a>
        )}
        {repoPrivate && (
          <button
            id="repoLockedBtn"
            type="button"
            class="repo-locked-btn border bg-transparent px-4 py-2 text-xs font-mono"
            data-text="> [LOCKED]"
            aria-haspopup="dialog"
            aria-controls="accessDeniedModal"
          >
            &gt; [LOCKED]
          </button>
        )}
      </div>
    </div>
  </header>

  <!-- Image -->
  {image && (
    <div class="mt-5 border border-[#00ff41]/15">
      <img
        src={image}
        alt=""
        class="w-full"
        style={imageIsSvg ? undefined : "filter: sepia(0.2) hue-rotate(80deg) saturate(0.85) brightness(0.9);"}
      />
    </div>
  )}

  <!-- Markdown content -->
  <article class="mt-6 prose-terminal">
    <div class="mb-2 text-[10px] text-[#007a1f] font-mono">
      <span class="text-[#00aa2a]">$</span> cat README.md
    </div>
    <div class="border border-[#00ff41]/12 bg-[#0a0a0a] p-6">
      <Content />
    </div>
  </article>

  {repoPrivate && (
    <div
      id="accessDeniedModal"
      class="access-denied-modal fixed inset-0 z-[80] hidden items-start justify-center bg-black/85 backdrop-blur-sm px-4 pt-[7vh] pb-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="accessDeniedTitle"
      data-slug={slug}
      data-classification={lock.classification}
      data-reason={lock.reason}
    >
      <div class="ad-window relative w-full max-w-2xl bg-[#0a0a0a] border border-[#ff3030]/50 shadow-[0_0_40px_rgba(255,48,48,0.25)]">
        <!-- Title bar -->
        <div class="flex items-center gap-2 border-b border-[#ff3030]/30 bg-[#0d0d0d] px-3 py-2">
          <span class="inline-block w-2.5 h-2.5 bg-[#ff3030]"></span>
          <span class="inline-block w-2.5 h-2.5 bg-[#7a7068]"></span>
          <span class="inline-block w-2.5 h-2.5 bg-[#7a7068]"></span>
          <span id="accessDeniedTitle" class="ml-3 text-[10px] text-[#7a7068] font-mono tracking-wider">
            ssh: git@github.com:gchuinard/private, bash
          </span>
          <button
            id="accessDeniedClose"
            type="button"
            class="ml-auto text-[10px] text-[#7a7068] hover:text-[#ff3030] font-mono"
            aria-label="Close"
          >[ ESC ]</button>
        </div>

        <!-- Terminal body -->
        <div
          id="accessDeniedOutput"
          class="px-5 py-4 text-[12px] leading-relaxed font-mono min-h-[320px] max-h-[60vh] overflow-y-auto"
        ></div>
      </div>
    </div>
  )}

</Base>

<style>
  /* Terminal prose styles for markdown content */
  .prose-terminal :global(h1),
  .prose-terminal :global(h2),
  .prose-terminal :global(h3),
  .prose-terminal :global(h4) {
    color: #00ff41;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  .prose-terminal :global(h2)::before { content: "## "; color: #007a1f; }
  .prose-terminal :global(h3)::before { content: "### "; color: #007a1f; }

  .prose-terminal :global(p) {
    color: #00aa2a;
    font-size: 0.875rem;
    line-height: 1.7;
    margin-bottom: 1em;
  }

  .prose-terminal :global(a) {
    color: #00ff41;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose-terminal :global(a:hover) { color: #39ff14; }

  .prose-terminal :global(ul),
  .prose-terminal :global(ol) {
    color: #00aa2a;
    font-size: 0.875rem;
    padding-left: 1.5rem;
    margin-bottom: 1em;
  }

  .prose-terminal :global(li)::marker { color: #007a1f; }

  .prose-terminal :global(code) {
    color: #00ff41;
    background: #080808;
    border: 1px solid rgba(0, 255, 65, 0.2);
    padding: 0.1em 0.4em;
    font-size: 0.8rem;
  }

  .prose-terminal :global(pre) {
    background: #080808 !important;
    border: 1px solid rgba(0, 255, 65, 0.18);
    padding: 1rem;
    overflow-x: auto;
  }

  .prose-terminal :global(pre code) {
    background: transparent;
    border: none;
    padding: 0;
    color: #00cc35;
  }

  .prose-terminal :global(blockquote) {
    border-left: 2px solid rgba(0, 255, 65, 0.4);
    padding-left: 1rem;
    color: #007a1f;
    font-style: normal;
  }

  .prose-terminal :global(blockquote)::before {
    content: "// ";
    color: #005c17;
  }

  .prose-terminal :global(hr) {
    border-color: rgba(0, 255, 65, 0.15);
  }

  .prose-terminal :global(strong) { color: #00ff41; }
  .prose-terminal :global(em)     { color: #00cc35; font-style: normal; }

  /* ──── REPO LOCKED BUTTON, GLITCH ───────────────────────── */
  .repo-locked-btn {
    position: relative;
    /* Au repos : rouge calme, raccord avec le thème (même retenue que le bouton
       vert « > code »). Le rouge vif « access denied » est réservé au survol. */
    color: #cc5a4d;
    border-color: rgba(255, 60, 60, 0.25);
    letter-spacing: 0.05em;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    cursor: pointer;
  }
  .repo-locked-btn::before,
  .repo-locked-btn::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    padding: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.1s;
  }
  .repo-locked-btn::before { color: #ff3030; transform: translate(-1px, 0); }
  .repo-locked-btn::after  { color: #00ff41; transform: translate(1px, 0); }

  .repo-locked-btn:hover {
    color: #ff3030;
    border-color: rgba(255, 60, 60, 0.55);
    background: rgba(255, 48, 48, 0.05);
    animation: glitch-jitter 0.25s steps(2) infinite;
  }
  .repo-locked-btn:hover::before,
  .repo-locked-btn:hover::after {
    opacity: 0.6;
    animation: glitch-shift 0.4s steps(3) infinite;
  }

  @keyframes glitch-jitter {
    0%, 100% { transform: translate(0, 0); }
    50%      { transform: translate(0.5px, -0.5px); }
  }
  @keyframes glitch-shift {
    0%   { transform: translate(-2px, 0); }
    33%  { transform: translate(2px, 1px); }
    66%  { transform: translate(-1px, -1px); }
    100% { transform: translate(2px, 0); }
  }

  /* ──── ACCESS DENIED MODAL ───────────────────────────────── */
  .access-denied-modal.is-open {
    display: flex !important;
    animation: ad-fade-in 0.18s ease-out;
  }
  .ad-window {
    animation: ad-window-in 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  @keyframes ad-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes ad-window-in {
    from { opacity: 0; transform: translateY(8px) scale(0.985); }
    to   { opacity: 1; transform: translateY(0)   scale(1);     }
  }

  #accessDeniedOutput {
    color: #00aa2a;
  }
  #accessDeniedOutput .ad-prompt  { color: #00ff41; }
  #accessDeniedOutput .ad-info    { color: #007a1f; }
  #accessDeniedOutput .ad-muted   { color: #005c17; }
  #accessDeniedOutput .ad-warn    { color: #ffaa00; }
  #accessDeniedOutput .ad-error   { color: #ff3030; font-weight: 700; }
  #accessDeniedOutput .ad-fatal   {
    color: #ff3030;
    font-weight: 700;
    animation: ad-flicker 1.4s infinite;
  }
  #accessDeniedOutput .ad-blink::after {
    content: "▮";
    color: #00ff41;
    animation: ad-blink 0.8s steps(2, jump-none) infinite;
    margin-left: 2px;
  }
  @keyframes ad-flicker {
    0%, 100% { opacity: 1; }
    47%      { opacity: 1; }
    50%      { opacity: 0.55; }
    53%      { opacity: 1; }
  }
  @keyframes ad-blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0; }
  }
</style>

<script>
  // ── ACCESS DENIED MODAL, TERMINAL TYPEWRITER ──────────────────
  const btn    = document.getElementById('repoLockedBtn');
  const modal  = document.getElementById('accessDeniedModal') as HTMLElement | null;
  const output = document.getElementById('accessDeniedOutput');
  const close  = document.getElementById('accessDeniedClose');

  if (btn && modal && output && close) {
    const slug = modal.dataset.slug ?? 'private-repo';
    const classification = modal.dataset.classification ?? 'private repository';
    const reason = modal.dataset.reason ?? 'code source confidentiel';

    // Sequence of lines to print. [delay_after_previous_ms, html]
    const sequence: [number, string][] = [
      [120,  `<p><span class="ad-prompt">$</span> git clone https://github.com/gchuinard/${slug}.git</p>`],
      [320,  `<p class="ad-info">Cloning into '${slug}'...</p>`],
      [480,  `<p class="ad-muted">Username for 'https://github.com': <span class="ad-info">anonymous</span></p>`],
      [520,  `<p class="ad-muted">Password for 'https://anonymous@github.com': <span class="ad-info">••••••••••••</span></p>`],
      [740,  `<p class="ad-warn">remote: Support for password authentication was removed on August 13, 2021.</p>`],
      [180,  `<p class="ad-warn">remote: Please see https://docs.github.com/get-started/getting-started-with-git</p>`],
      [300,  `<p class="ad-error">fatal: Authentication failed for 'https://github.com/gchuinard/${slug}.git'</p>`],
      [620,  `<p class="ad-muted">&nbsp;</p>`],
      [80,   `<p><span class="ad-prompt">$</span> ssh -T git@github.com</p>`],
      [380,  `<p class="ad-error">Permission denied (publickey).</p>`],
      [600,  `<p class="ad-muted">&nbsp;</p>`],
      [80,   `<p class="ad-info">[*] retry attempt 1/3 ........... <span class="ad-error">FAILED</span></p>`],
      [380,  `<p class="ad-info">[*] retry attempt 2/3 ........... <span class="ad-error">FAILED</span></p>`],
      [380,  `<p class="ad-info">[*] retry attempt 3/3 ........... <span class="ad-error">LOCKED</span></p>`],
      [600,  `<p class="ad-muted">&nbsp;</p>`],
      [80,   `<p class="ad-fatal">╔══════════════════════════════════════════╗</p>`],
      [40,   `<p class="ad-fatal">║          [!] ACCESS DENIED [!]           ║</p>`],
      [40,   `<p class="ad-fatal">╚══════════════════════════════════════════╝</p>`],
      [400,  `<p class="ad-muted">&nbsp;</p>`],
      [80,   `<p class="ad-info">visibility&nbsp;&nbsp;&nbsp;: <span class="ad-error">private</span></p>`],
      [120,  `<p class="ad-info">classification: <span class="ad-warn">${classification}</span></p>`],
      [120,  `<p class="ad-info">reason&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;: ${reason}</p>`],
      [400,  `<p class="ad-muted">&nbsp;</p>`],
      [80,   `<p class="ad-muted">// le code source de ce projet est confidentiel.</p>`],
      [80,   `<p class="ad-muted">// une démo live ou un walkthrough technique reste possible</p>`],
      [80,   `<p class="ad-muted">// sur demande, voir /contact.</p>`],
      [400,  `<p class="ad-muted">&nbsp;</p>`],
      [80,   `<p class="ad-prompt ad-blink">$ </p>`],
    ];

    let timers: number[] = [];

    function reset() {
      timers.forEach(t => window.clearTimeout(t));
      timers = [];
      if (output) output.innerHTML = '';
    }

    function play() {
      reset();
      let cumul = 0;
      sequence.forEach(([wait, html]) => {
        cumul += wait;
        const id = window.setTimeout(() => {
          if (!output) return;
          const wrap = document.createElement('div');
          wrap.innerHTML = html;
          while (wrap.firstChild) output.appendChild(wrap.firstChild);
          output.scrollTop = output.scrollHeight;
        }, cumul);
        timers.push(id);
      });
    }

    function open() {
      modal!.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      play();
    }

    function shut() {
      modal!.classList.remove('is-open');
      document.body.style.overflow = '';
      reset();
    }

    btn.addEventListener('click', open);
    close.addEventListener('click', shut);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) shut();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal!.classList.contains('is-open')) shut();
    });
  }
</script>
