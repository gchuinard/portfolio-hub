---
import "../styles/tailwind.css";
import "../styles/base-boot.css";
import baseClientScript from "../scripts/base-client.ts?url";

const {
  title = "Gautier Playbook",
  description = "Gautier Playbook — projets, compétences, PO, QA et certifications de Gautier Chuinard."
} = Astro.props;

const currentPath = Astro.url.pathname;

const links = [
  { href: "/projects",       label: "projets",        i18n: "nav.projects" },
  { href: "/skills",         label: "compétences",    i18n: "nav.skills" },
  { href: "/certifications", label: "certifications", i18n: "nav.certifications" },
  { href: "/contact",        label: "contact",        i18n: "nav.contact" },
];

function isActive(path: string) {
  if (path === "/" && currentPath === "/") return true;
  if (path === "/projects")       return currentPath.startsWith("/projects");
  if (path === "/skills")         return currentPath.startsWith("/skills");
  if (path === "/certifications") return currentPath.startsWith("/certifications");
  if (path === "/contact")        return currentPath.startsWith("/contact");
  return false;
}

const swatchesDark = [
  { id: "ph", hue:   0, title: "Phosphore" },
  { id: "am", hue:  55, title: "Cyan"     },
  { id: "cy", hue: 130, title: "Purple"      },
  { id: "rg", hue: -60, title: "Jaune"     },
];
const swatchesLight = [
  { id: "cr", hue:   0, title: "Craie"     },
  { id: "ln", hue:  30, title: "Lin"       },
];
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <!-- Applique le thème sauvegardé avant le premier rendu pour éviter le flash -->
    <script is:inline>
      (function() {
        try {
          const t = JSON.parse(localStorage.getItem('gh-theme') || '{}');
          const forceBoot = new URLSearchParams(window.location.search).get('boot') === '1';
          if (t.hue  != null) document.documentElement.style.setProperty('--hue', t.hue + 'deg');
          if (t.dim)          document.documentElement.setAttribute('data-dim', '');
          if (t.light)        document.documentElement.setAttribute('data-light', '');
          if (t.lang)         document.documentElement.setAttribute('data-lang', t.lang);
          if (t.lang && t.lang !== 'fr') document.documentElement.style.visibility = 'hidden';
          if (forceBoot) {
            sessionStorage.removeItem('gp-boot-seen');
            document.documentElement.setAttribute('data-force-boot', '');
          } else if (sessionStorage.getItem('gp-boot-seen') === '1') {
            document.documentElement.setAttribute('data-skip-boot', '');
          }
        } catch(e) {}
      })();
    </script>
  </head>

  <body class="min-h-screen">
    <div id="boot-overlay" aria-hidden="true">
      <div class="boot-box">
        <p class="boot-line boot-line--hidden"><span class="boot-prompt">$</span> power on --system</p>
        <p class="boot-line boot-line--hidden">[ OK ] alimentation initialisée</p>
        <p class="boot-line boot-line--hidden"><span class="boot-prompt">$</span> connect --portfolio</p>
        <p class="boot-line boot-line--hidden">connexion en cours<span class="boot-dots"></span></p>
      </div>
    </div>

    <div id="theme-root" class="app-shell app-shell--booting">

      <!-- HEADER -->
      <header class="power-node sticky top-0 z-40 border-b border-[#00ff41]/12 bg-[#0d0d0d]/95"
              style="backdrop-filter: blur(4px);">
        <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3 text-sm gap-4">

          <!-- Logo terminal -->
          <a href="/" class="flex items-baseline gap-0 font-mono text-sm tracking-tight flex-shrink-0">
            <span class="text-[#00aa2a]">gautier</span>
            <span class="text-[#007a1f]">@</span>
            <span class="text-[#00ff41]">playbook</span>
            <span class="text-[#00aa2a]">:~$</span>
            <span class="ml-1 inline-block w-[0.5em] h-[0.85em] bg-[#00ff41] align-middle animate-[blink_1s_step-end_infinite]"></span>
          </a>

          <!-- Navigation principale -->
          <div class="flex items-center gap-5 flex-1 justify-center">
            {links.map((link) => {
              const active = isActive(link.href);
              return (
                <a
                  href={link.href}
                  class={`relative font-mono text-sm transition-colors ${
                    active ? "text-[#00ff41]" : "text-[#00aa2a] hover:text-[#00ff41]"
                  }`}
                >
                  {active && <span class="text-[#007a1f] select-none">&gt; </span>}
                  <span data-i18n={link.i18n}>{link.label}</span>
                  {active && (
                    <span class="absolute inset-x-0 -bottom-[13px] h-[1px] bg-[#00ff41]/40"></span>
                  )}
                </a>
              );
            })}
          </div>

          <!-- Selecteur de theme -->
          <div class="flex items-center gap-2 border-l border-[#00ff41]/15 pl-3 flex-shrink-0">

            <!-- Swatches sombres -->
            <div class="flex items-center gap-1.5">
              {swatchesDark.map(s => (
                <button
                  data-hue={s.hue}
                  data-light="false"
                  title={s.title}
                  class={`swatch-${s.id} swatch-btn w-2.5 h-2.5 bg-[#00ff41] transition-all hover:scale-125 outline-none`}
                  aria-label={s.title}
                ></button>
              ))}
            </div>

            <!-- Séparateur sombre/clair -->
            <span class="text-[#007a1f]/40 text-xs">|</span>

            <!-- Swatches clairs -->
            <div class="flex items-center gap-1.5">
              {swatchesLight.map(s => (
                <button
                  data-hue={s.hue}
                  data-light="true"
                  title={s.title}
                  class={`swatch-${s.id} swatch-btn w-2.5 h-2.5 bg-transparent border border-[#00ff41] transition-all hover:scale-125 outline-none`}
                  aria-label={s.title}
                ></button>
              ))}
            </div>

            <!-- Séparateur -->
            <span class="text-[#007a1f]/40 text-xs">|</span>

            <!-- Toggle dim -->
            <button
              id="dim-toggle"
              class="text-[9px] text-[#007a1f] border border-[#00ff41]/15 px-1.5 py-0.5
                     hover:text-[#00ff41] hover:border-[#00ff41]/40 transition-colors font-mono"
              title="Contraste du fond"
            >
              dim
            </button>

            <!-- Séparateur -->
            <span class="text-[#007a1f]/40 text-xs">|</span>

            <!-- Toggle langue -->
            <button
              id="lang-toggle"
              class="text-[9px] text-[#007a1f] border border-[#00ff41]/15 px-1.5 py-0.5
                     hover:text-[#00ff41] hover:border-[#00ff41]/40 transition-colors font-mono"
              title="Switch language / Changer la langue"
            >
              EN
            </button>
          </div>

        </nav>
      </header>

      <!-- MAIN -->
      <main class="power-node mx-auto max-w-5xl px-4 py-8">
        <slot />
      </main>

      <!-- FOOTER -->
      <footer class="power-node border-t border-[#00ff41]/10 mt-10">
        <div class="mx-auto max-w-5xl px-4 py-4 text-xs text-[#007a1f] flex justify-between items-center">
          <span># © 2026 gautier@playbook — all rights reserved</span>
          <span class="text-[#005c17]">// built with astro + tailwind</span>
        </div>
      </footer>

    </div><!-- #theme-root -->

  <!-- Script synchrone : applique la langue AVANT le premier rendu (évite le flash FR→EN) -->
  <script is:inline>
  (function() {
    try {
      var lang = (JSON.parse(localStorage.getItem('gh-theme') || '{}').lang) || 'fr';
      if (lang !== 'fr') {
        var d = {
          'nav.projects':'projects','nav.skills':'skills','nav.certifications':'certifications','nav.contact':'contact',
          'index.typewriter':"Hi, I'm Gautier\nproduct owner & product-focused QA.",
          'index.hero.body':"I drive digital projects, organize quality (automated testing, monitoring) and bridge the gap between technical teams and the business, with a strong user-focused mindset.",
          'index.hero.cta1':'> discover my projects',
          'index.hero.cta2':'certifications & scrum path \u2192',
          'index.nav.projects.label':'project hub',
          'index.nav.projects.heading':'Projects & experience',
          'index.nav.projects.desc':'Detailed cards, stack, tags, Demo & Code links, advanced filters.',
          'index.nav.projects.link':'view projects',
          'index.nav.skills.label':'skills',
          'index.nav.skills.heading':'Skills & tools',
          'index.nav.skills.desc':'Overview: technical skills, soft skills, frameworks and visual indicators.',
          'index.nav.skills.link':'explore skills',
          'index.nav.certs.label':'scrum & others',
          'index.nav.certs.heading':'Certifications',
          'index.nav.certs.desc':'Timeline and grid: PAL I, Scrum.org path, other key certifications.',
          'index.nav.certs.link':'view certifications',
          'index.about.heading':'What I like to do',
          'index.about.body':"Guide teams to ensure value delivery, set up tools that make teams more efficient: automated tests, monitoring dashboards, automation scripts\u2026 And always keep a user-centric vision.",
          'index.contact.heading':'Want to discuss?',
          'index.contact.body':"A project, a testing pipeline idea, something unusual? I'm always up for a chat.",
          'index.contact.link':'open contact form',
          'projects.heading':'Project Hub',
          'projects.entries':'entries found',
          'projects.filter.hint':' \u2014 use filters to refine',
          'projects.filter.label':'filter_mode:',
          'projects.filter.and':'AND','projects.filter.or':'OR',
          'skills.heading':'My Skills',
          'skills.dev.heading':'// Development',
          'skills.qa.heading':'// QA & Automation',
          'skills.pro.heading':'// Professional',
          'skills.tools.heading':'// Tools',
          'skills.legend':'Expert \xb7 Advanced \xb7 Intermediate \xb7 Learning',
          'certs.badge.target':'GOAL',
          'certs.target.label':'// target certification',
          'certs.link':'> view certificate',
          'certs.target.link':'// in progress',
          'certs.filter.label':'filter_mode:',
          'certs.filter.and':'AND','certs.filter.or':'OR',
          'contact.heading':'Contact',
          'contact.intro':'// Want to talk about a project, QA, automated testing or home automation geekery? Write to me.',
          'contact.info.heading':'// My info',
          'contact.info.body':"Email is the easiest way to reach me. I reply as soon as possible, especially if it's about automated testing, monitoring or self-hosted quirky tech.",
          'contact.networks.label':'ls ./networks/',
          'contact.form.heading':'// Send me a message',
          'contact.form.name':'name:',
          'contact.form.name.ph':"_ who's writing?",
          'contact.form.email.ph':'_ you@example.com',
          'contact.form.subject':'subject:',
          'contact.form.subject.ph':'_ what are we talking about?',
          'contact.form.message':'message:',
          'contact.form.message.ph':'_ context is always helpful',
          'contact.form.submit':'> send (mockup)',
          'contact.form.email.link':'// or write directly by email \u2192',
        };
        // Éléments data-i18n
        var els = document.querySelectorAll('[data-i18n]');
        for (var i = 0; i < els.length; i++) {
          var v = d[els[i].getAttribute('data-i18n')];
          if (v != null) els[i].textContent = v;
        }
        // Placeholders
        var pls = document.querySelectorAll('[data-i18n-placeholder]');
        for (var i = 0; i < pls.length; i++) {
          var v = d[pls[i].getAttribute('data-i18n-placeholder')];
          if (v != null) pls[i].placeholder = v;
        }
        // Titres/descriptions dynamiques (projets, etc.)
        var dyn = document.querySelectorAll('[data-lang-fr]');
        for (var i = 0; i < dyn.length; i++) {
          var en = dyn[i].getAttribute('data-lang-en');
          if (en) dyn[i].textContent = en;
        }
      }
    } catch(e) {}
    // Rétablit toujours la visibilité
    document.documentElement.style.visibility = '';
  })();
  </script>

  </body>
</html>
<script type="module" src={baseClientScript}></script>
