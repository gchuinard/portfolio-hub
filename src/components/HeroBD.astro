---
const skills = [
  { label: "Product Owner",  pct: 95, tag: "EXPERT" },
  { label: "Scrum",   pct: 93, tag: "EXPERT" },
  { label: "Playwright",     pct: 88, tag: "ADV"    },
  { label: "Postman / API",  pct: 85, tag: "ADV"    },
  { label: "Monitoring",     pct: 78, tag: "ADV"    },
  { label: "CI/CD",     pct: 74, tag: "ADV"    },
  { label: "Docker",         pct: 70, tag: "INT"    },
];
---

<div class="border border-[#00ff41]/25 bg-[#080808] font-mono flex-shrink-0 self-start min-w-[320px]">

  <!-- Barre de titre -->
  <div class="border-b border-[#00ff41]/12 px-3 py-1.5 text-[10px] text-[#007a1f] flex items-center gap-2">
    <span class="text-[#00aa2a]">$</span>
    <span>identify --skills gautier.local</span>
  </div>

  <!-- Nom avec effet glitch -->
  <div class="px-5 pt-5 pb-3 select-none">
    <h2
      class="glitch-name text-[2.8rem] font-bold leading-none tracking-[0.1em]"
      data-text="GAUTIER"
    >
      GAUTIER
    </h2>
    <p class="status-wrap text-[10px] text-[#007a1f] mt-1.5 tracking-[0.18em]">
      <span class="status-ghost">[ IDENTITÉ CONFIRMÉE ]</span>
      <span id="bd-status" class="status-live"></span>
    </p>
  </div>

  <!-- Separateur -->
  <div class="mx-5 border-t border-[#00ff41]/12 mb-3"></div>

  <!-- Barres de competences -->
  <div class="px-5 pb-5 space-y-2.5">
    <p class="text-[10px] text-[#007a1f] mb-3">
      <span class="text-[#00aa2a]">$</span> cat skills.log
    </p>

    {skills.map((s, i) => (
      <div class="flex items-center gap-2">
        <span class="text-[10px] text-[#00aa2a] w-28 flex-shrink-0 truncate">{s.label}</span>
        <div class="flex-1 h-2 bg-[#0d0d0d] border border-[#00ff41]/12 overflow-hidden">
          <div
            class="skill-bar h-full bg-[#00ff41]"
            style={`--target: ${s.pct}%; transition-delay: ${i * 100}ms;`}
          ></div>
        </div>
        <span class="text-[10px] text-[#005c17] w-7 text-right flex-shrink-0">{s.pct}%</span>
        <span class={`text-[9px] font-bold px-1 py-0.5 flex-shrink-0 border ${
          s.tag === 'EXPERT' ? 'border-[#00ff41]/50 text-[#00ff41] bg-[#003b0f]' :
          s.tag === 'ADV'    ? 'border-[#00ff41]/30 text-[#00cc35] bg-transparent' :
                               'border-[#00ff41]/15 text-[#007a1f] bg-transparent'
        }`}>{s.tag}</span>
      </div>
    ))}

    <p class="text-[10px] text-[#005c17] pt-1">
      <a href="/skills" class="hover:text-[#00aa2a] transition-colors">→ ./skills --full</a>
    </p>
  </div>
</div>

<style>
  /* ── Nom glitch ──────────────────────────────── */
  .glitch-name {
    position: relative;
    color: #00ff41;
    text-shadow:
      0 0 8px rgba(0, 255, 65, 0.6),
      0 0 25px rgba(0, 255, 65, 0.25);
    animation: glitch-main 5s infinite;
  }

  .glitch-name::before {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    color: #ff0040;
    text-shadow: none;
    opacity: 0;
    animation: glitch-red 5s infinite;
  }

  .glitch-name::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    color: #00cfff;
    text-shadow: none;
    opacity: 0;
    animation: glitch-blue 5s infinite;
  }

  @keyframes glitch-main {
    0%, 84%, 100% { transform: translate(0); text-shadow: 0 0 8px rgba(0,255,65,.6), 0 0 25px rgba(0,255,65,.25); }
    85% { transform: translateX(-4px) skewX(-1deg); text-shadow:  4px 0 #ff0040, -4px 0 #00cfff; }
    86% { transform: translateX( 4px) skewX( 2deg); text-shadow: -4px 0 #ff0040,  4px 0 #00cfff; }
    87% { transform: translateX(-2px);               text-shadow:  2px 0 #ff0040, -2px 0 #00cfff; }
    88% { transform: translate(0); text-shadow: 0 0 8px rgba(0,255,65,.6), 0 0 25px rgba(0,255,65,.25); }
    93% { transform: translateX( 5px) skewX(-2deg); text-shadow: -5px 0 #ff0040,  5px 0 #00cfff; }
    94% { transform: translateX(-5px);               text-shadow:  5px 0 #ff0040, -5px 0 #00cfff; }
    95% { transform: translate(0); text-shadow: 0 0 8px rgba(0,255,65,.6), 0 0 25px rgba(0,255,65,.25); }
  }

  @keyframes glitch-red {
    0%, 84%, 100% { opacity: 0; }
    85% { opacity: .8; transform: translateX(-6px); clip-path: inset(10% 0 55% 0); }
    86% { opacity: .6; transform: translateX( 4px); clip-path: inset(50% 0 10% 0); }
    87% { opacity: 0; }
    93% { opacity: .7; transform: translateX(-8px); clip-path: inset(5%  0 70% 0); }
    94% { opacity: .5; transform: translateX( 5px); clip-path: inset(65% 0 5%  0); }
    95% { opacity: 0; }
  }

  @keyframes glitch-blue {
    0%, 84%, 100% { opacity: 0; }
    85% { opacity: .7; transform: translateX( 6px); clip-path: inset(40% 0 25% 0); }
    86% { opacity: .5; transform: translateX(-4px); clip-path: inset(15% 0 50% 0); }
    87% { opacity: 0; }
    93% { opacity: .6; transform: translateX( 8px); clip-path: inset(55% 0 15% 0); }
    94% { opacity: .4; transform: translateX(-5px); clip-path: inset(10% 0 60% 0); }
    95% { opacity: 0; }
  }

  /* ── Barres de competences ───────────────────── */
  .skill-bar {
    width: 0%;
    transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 2px 0 6px rgba(0, 255, 65, 0.5);
  }
  .skill-bar.animate { width: var(--target); }

  .status-wrap {
    position: relative;
    display: inline-block;
    white-space: pre;
  }

  .status-ghost {
    visibility: hidden;
  }

  .status-live {
    position: absolute;
    inset: 0;
  }
</style>

<script>
  // ── Anime les barres a l'apparition du bloc ───
  const bars = document.querySelectorAll('.skill-bar') as NodeListOf<HTMLElement>;
  const observer = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) {
      setTimeout(() => bars.forEach(b => b.classList.add('animate')), 400);
      observer.disconnect();
    }
  }, { threshold: 0.3 });
  const wrap = bars[0]?.closest('[class*="border"]');
  if (wrap) observer.observe(wrap);

  // ── Fait tourner le texte de statut ───────────
  const statusEl = document.getElementById('bd-status');
  if (statusEl) {
    const _l = (JSON.parse(localStorage.getItem('gh-theme') || '{}').lang) ?? 'fr';
    const msgs = _l === 'en'
      ? ['[ IDENTITY CONFIRMED ]', '[ ACCESS GRANTED ]', '[ SYSTEM ONLINE ]']
      : ['[ IDENTITÉ CONFIRMÉE ]', '[ ACCÈS AUTORISÉ ]', '[ SYSTÈME EN LIGNE ]'];
    let mi = 0, ci = 0, del = false;
    function tick() {
      const cur = msgs[mi];
      if (!del) {
        statusEl!.textContent = cur.slice(0, ++ci);
        if (ci === cur.length) { del = true; setTimeout(tick, 2200); return; }
        setTimeout(tick, 60);
      } else {
        statusEl!.textContent = cur.slice(0, --ci);
        if (ci === 0) { del = false; mi = (mi + 1) % msgs.length; setTimeout(tick, 350); return; }
        setTimeout(tick, 28);
      }
    }
    setTimeout(tick, 1000);
  }
</script>
