---
const skills = [
  { label: "Product Owner",  pct: 95, tag: "EXPERT" },
  { label: "Scrum / SAFe",   pct: 93, tag: "EXPERT" },
  { label: "Playwright",     pct: 88, tag: "ADV"    },
  { label: "Postman / API",  pct: 85, tag: "ADV"    },
  { label: "Monitoring",     pct: 74, tag: "INT"    },
  { label: "Docker",         pct: 70, tag: "INT"    },
  { label: "JavaScript",     pct: 78, tag: "ADV"    },
];
---

<div class="border border-[#00ff41]/25 bg-[#080808] font-mono flex-shrink-0 self-start min-w-[340px]">

  <!-- Title bar -->
  <div class="border-b border-[#00ff41]/12 px-3 py-1.5 text-[10px] text-[#007a1f] flex items-center gap-2">
    <span class="text-[#00aa2a]">$</span>
    <span>cat skills.log</span>
  </div>

  <!-- Bars -->
  <div class="p-4 space-y-3">
    <div class="text-[10px] text-[#005c17] border-b border-[#00ff41]/08 pb-2 mb-3">
      ──────────────────────────────────────
    </div>

    {skills.map((s, i) => (
      <div class="flex items-center gap-2">
        <!-- Label -->
        <span class="text-[11px] text-[#00aa2a] w-32 flex-shrink-0 truncate">{s.label}</span>

        <!-- Bar track -->
        <div class="flex-1 h-2.5 bg-[#0d0d0d] border border-[#00ff41]/15 overflow-hidden">
          <div
            class="skill-bar h-full bg-[#00ff41]"
            style={`--target: ${s.pct}%; transition-delay: ${i * 120}ms;`}
          ></div>
        </div>

        <!-- Percent -->
        <span class="text-[10px] text-[#007a1f] w-8 text-right flex-shrink-0">{s.pct}%</span>

        <!-- Badge -->
        <span class={`text-[9px] font-bold px-1.5 py-0.5 flex-shrink-0 border ${
          s.tag === 'EXPERT' ? 'border-[#00ff41]/50 text-[#00ff41] bg-[#003b0f]' :
          s.tag === 'ADV'    ? 'border-[#00ff41]/30 text-[#00cc35] bg-[#002a0a]' :
                               'border-[#00ff41]/15 text-[#00aa2a] bg-transparent'
        }`}>{s.tag}</span>
      </div>
    ))}

    <div class="text-[10px] text-[#005c17] border-t border-[#00ff41]/08 pt-2 mt-3">
      ──────────────────────────────────────
    </div>
    <p class="text-[10px] text-[#007a1f]">
      {skills.length} skills loaded
      <span class="text-[#005c17]"> — <a href="/skills" class="hover:text-[#00aa2a] transition-colors">./skills --full</a> for more</span>
    </p>
  </div>
</div>

<style>
  .skill-bar {
    width: 0%;
    transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 2px 0 8px rgba(0, 255, 65, 0.4);
  }

  /* Trigger animation when visible */
  .skill-bar.animate {
    width: var(--target);
  }
</style>

<script>
  const bars = document.querySelectorAll('.skill-bar') as NodeListOf<HTMLElement>;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        // Small initial delay then trigger all bars
        setTimeout(() => {
          bars.forEach(bar => bar.classList.add('animate'));
        }, 300);
        observer.disconnect();
      }
    });
  }, { threshold: 0.3 });

  const container = bars[0]?.closest('[class*="border"]');
  if (container) observer.observe(container);
</script>
