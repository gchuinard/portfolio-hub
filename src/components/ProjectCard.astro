---
const { entry } = Astro.props;

const href = `/projects/${entry.data.slug ?? entry.slug}`;
const tags  = entry.data.tags  ?? [];
const stack = entry.data.stack ?? [];
const img   = entry.data.image;
const statuses = entry.data.status ?? [];

const dataTags = tags.map(t => t.toLowerCase()).join(",");

const statusMap = {
  "online":      { label: "[ONLINE]",   color: "border-[#00ff41]/80 text-[#00ff41] bg-[#002a0a]",   pulse: true  },
  "offline":     { label: "[OFFLINE]",  color: "border-[#00ff41]/15 text-[#005c17] bg-transparent", pulse: false },
  "new":         { label: "[NEW]",      color: "border-[#00ff41]/60 text-[#00ff41] bg-[#003b0f]",   pulse: false },
  "updated":     { label: "[UPD]",      color: "border-[#00ff41]/35 text-[#00cc35] bg-[#002a0a]",   pulse: false },
  "in-progress": { label: "[WIP]",      color: "border-[#00ff41]/25 text-[#00aa2a] bg-transparent", pulse: false },
  "planned":     { label: "[PLANNED]",  color: "border-[#00ff41]/12 text-[#007a1f] bg-transparent", pulse: false },
  "beta":        { label: "[BETA]",     color: "border-[#00ff41]/70 text-[#00ff41] bg-[#001f09]",   pulse: true  },
};

const badges = statuses.map(s => statusMap[s]).filter(Boolean);
---

<a
  href={href}
  data-tags={dataTags}
  class="group block border border-[#00ff41]/15 bg-[#0a0a0a] overflow-hidden
         hover:border-[#00ff41]/45 transition-colors"
  style="border-radius: 0;"
>

  <!-- Image / placeholder -->
  <div class="relative aspect-video overflow-hidden border-b border-[#00ff41]/10">
    {img ? (
      <img
        src={img}
        class="h-full w-full object-cover transition group-hover:opacity-90"
        loading="lazy"
        style="filter: sepia(0.25) hue-rotate(80deg) saturate(0.8) brightness(0.85);"
      />
    ) : (
      <div class="h-full w-full bg-[#080808] grid place-items-center font-mono">
        <div class="text-center text-[#007a1f]">
          <p class="text-xs">[ no preview ]</p>
          <p class="text-[10px] text-[#005c17] mt-1">img not found</p>
        </div>
      </div>
    )}

    {badges.length > 0 && (
      <div class="absolute left-2 top-2 flex flex-wrap gap-1">
        {badges.map(badge => (
          <span
            class={`text-[10px] font-bold px-2 py-0.5 border font-mono tracking-wider flex items-center gap-1 ${badge.color}`}
          >
            {badge.pulse && (
              <span class="inline-block w-1.5 h-1.5 rounded-full bg-current animate-pulse" />
            )}
            {badge.label}
          </span>
        ))}
      </div>
    )}
  </div>

  <!-- Info -->
  <div class="p-4">
    <!-- Title with prompt -->
    <p class="text-[10px] text-[#007a1f] font-mono mb-0.5">
      <span class="text-[#00aa2a]">$</span> cat {entry.data.slug ?? entry.slug}.md
    </p>
    <h3 class="text-sm font-bold text-[#00ff41] group-hover:text-[#39ff14] transition-colors mb-1"
        data-lang-fr={entry.data.title}
        data-lang-en={entry.data.titleEn ?? entry.data.title}>
      {entry.data.title}
    </h3>

    <p class="text-xs text-[#00aa2a] leading-relaxed"
       data-lang-fr={entry.data.description}
       data-lang-en={entry.data.descriptionEn ?? entry.data.description}>
      {entry.data.description}
    </p>

    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5" aria-label="Tags">
        {tags.map(t => (
          <span class="text-[10px] px-2 py-0.5 border border-[#00ff41]/15 bg-[#080808] text-[#007a1f] font-mono">
            #{t}
          </span>
        ))}
      </div>
    )}

    {stack.length > 0 && (
      <p class="mt-2 text-[10px] text-[#005c17] font-mono">
        <span class="text-[#007a1f]">stack:</span> {stack.join(" · ")}
      </p>
    )}
  </div>
</a>
